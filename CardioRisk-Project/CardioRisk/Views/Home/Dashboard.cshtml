@model CardioRisk.Models.DashboardViewModel
@{
    ViewBag.Title = "Dashboard";
}
<h2 class="mb-4"><i class="fas fa-chart-pie me-2 text-danger"></i>Dashboard</h2>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="stat-card" style="background:#3498db;">
            <div class="fs-1 fw-bold">@Model.TotalPatients</div>
            <div>Total Patients</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card" style="background:#27ae60;">
            <div class="fs-1 fw-bold">@Model.LowRiskCount</div>
            <div>Low Risk</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card" style="background:#e67e22;">
            <div class="fs-1 fw-bold">@Model.MediumRiskCount</div>
            <div>Medium Risk</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card" style="background:#c0392b;">
            <div class="fs-1 fw-bold">@(Model.HighRiskCount + Model.CriticalRiskCount)</div>
            <div>High / Critical</div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-5">
        <div class="card p-3">
            <h5 class="mb-3">Risk Distribution</h5>
            <canvas id="riskChart" height="250"></canvas>
        </div>
    </div>
    <div class="col-md-7">
        <div class="card p-3">
            <h5 class="mb-3">Recent Assessments</h5>
            <table class="table table-hover table-sm">
                <thead class="table-dark">
                    <tr><th>Patient</th><th>Risk</th><th>Confidence</th><th>Date</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var a in Model.RecentAssessments)
                    {
                        <tr>
                            <td>@a.PatientName</td>
                            <td>
                                <span class="badge bg-@(a.RiskClass == "Low" ? "success" : a.RiskClass == "Medium" ? "warning text-dark" : a.RiskClass == "High" ? "danger" : "dark")">
                                    @a.RiskClass
                                </span>
                            </td>
                            <td>@(a.ConfidenceScore.ToString("P1"))</td>
                            <td>@a.AssessmentDate.ToString("MM/dd/yyyy")</td>
                            <td><a href="@Url.Action("Profile","Patient",new{id=a.PatientID})" class="btn btn-xs btn-outline-primary btn-sm">View</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
    new Chart(document.getElementById('riskChart'), {
        type: 'doughnut',
        data: {
            labels: ['Low', 'Medium', 'High', 'Critical'],
            datasets: [{
                data: [@Model.LowRiskCount, @Model.MediumRiskCount, @Model.HighRiskCount, @Model.CriticalRiskCount],
                backgroundColor: ['#27ae60','#f39c12','#e74c3c','#2c3e50']
            }]
        },
        options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
    });
</script>
}
